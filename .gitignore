# Frames — never commit binary render output
*.png
*.jpg
*.jpeg
*.exr
*.tiff
*.bmp

# Exception: fixture frames ARE committed (small known-bad/known-good samples)
!tests/fixtures/**/*.png
!tests/fixtures/**/*.jpg
